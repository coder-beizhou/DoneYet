{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "办了么",
  "version": "1.0.0",
  "identifier": "com.doneyet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "上上签",
        "width": 470,
        "height": 720,
        "minWidth": 470,
        "minHeight": 360,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "maximizable": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
